{
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{"source": "**", "destination": "/index.html"}]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "alrasikhoon-57151",
          "appId": "1:276199755113:android:4e857305eac385d32781f8",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "alrasikhoon-57151",
          "appId": "1:276199755113:ios:7d12088a1d5663e22781f8",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "alrasikhoon-57151",
          "configurations": {
            "android": "1:276199755113:android:4e857305eac385d32781f8",
            "ios": "1:276199755113:ios:7d12088a1d5663e22781f8",
            "web": "1:276199755113:web:101e883fe6ba7d672781f8"
          }
        }
      }
    }
  },
  "firestore": {
    "database": "(default)",
    "location": "europe-west6",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099,
      "host": "0.0.0.0"
    },
    "firestore": {
      "port": 8080,
      "host": "0.0.0.0"
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}