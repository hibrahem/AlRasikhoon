rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isSupervisor() {
      return isAuthenticated() && getUserRole() == 'supervisor';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    // The canonical institute the signed-in user is bound to, read off
    // users/{uid}.institute_id (AgDR-0003: single source of truth for
    // supervisor scoping). Null when the field is absent.
    function callerInstituteId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institute_id;
    }

    // A supervisor scoped to the institute of the given student document data.
    // Compares student.institute_id against the supervisor's
    // users/{uid}.institute_id with NO multi-hop read (AgDR-0003 denormalizes
    // institute_id onto student docs). Defensive against students that pre-date
    // the field: a student with no institute_id ('institute_id' in data == false)
    // is treated as out-of-scope and DENIED, so a missing field never widens
    // access. Backfilling existing student docs is a tracked follow-up.
    function isSupervisorOfStudentInstitute(studentData) {
      return isSupervisor() &&
        ('institute_id' in studentData) &&
        studentData.institute_id != null &&
        studentData.institute_id == callerInstituteId();
    }

    // A supervisor scoped to the institute of the student referenced by a
    // session/sard record. Single get() on the student doc to read its
    // denormalized institute_id, compared against the supervisor's institute.
    function isSupervisorOfRecordStudent(recordData) {
      return isSupervisor() &&
        ('student_id' in recordData) &&
        get(/databases/$(database)/documents/students/$(recordData.student_id)).data.institute_id == callerInstituteId();
    }

    // Users collection
    match /users/{userId} {
      // Reads require auth. The username+password flow looks up users
      // from authenticated callers only (admin screens checking
      // username uniqueness, the auth listener loading the signed-in
      // user's doc, etc.). The legacy unauthenticated read carve-out
      // for email-link sign-in is gone.
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isTeacher() ||
        (isAuthenticated() && request.auth.uid == userId);
      // SuperAdmin may update any field on any user. A self-update (a
      // non-superadmin editing their own doc) is allowed for normal profile
      // fields ONLY — `role` and `institute_id` are frozen to their current
      // values. Without this guard a supervisor could self-promote to
      // role: 'super_admin' (mirrored into the Auth claim by syncRoleClaim) or
      // change their own institute_id and rescope every #28 check. Privilege
      // boundary: only a superadmin may move a user between roles/institutes.
      allow update: if isSuperAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.institute_id == resource.data.institute_id);
      allow delete: if isSuperAdmin();
    }

    // Institutes collection
    match /institutes/{instituteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated();
      // Allow create if: teacher, supervisor (only within their own institute —
      // teacher-parity student management, AgDR-0003 / #28), OR student creating
      // their own record (for invitation flow).
      allow create: if isTeacher() ||
        isSupervisorOfStudentInstitute(request.resource.data) ||
        (isAuthenticated() && getUserRole() == 'student' && request.resource.data.user_id == request.auth.uid);
      // Allow update if: teacher, supervisor (scoped to their institute on BOTH
      // the existing doc and the incoming doc, so a supervisor can neither edit
      // a student outside their institute nor move one in/out of it), OR student
      // claiming their own record (setting user_id to their own UID during
      // migration repair).
      allow update: if isTeacher() ||
        (isSupervisorOfStudentInstitute(resource.data) &&
         isSupervisorOfStudentInstitute(request.resource.data)) ||
        (isAuthenticated() &&
         getUserRole() == 'student' &&
         request.resource.data.user_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user_id', 'updated_at']));
      allow delete: if isSuperAdmin();
    }

    // Curriculum (read-only for all authenticated users)
    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Session records — teachers write any; supervisors write only for a
    // student in their own institute (teacher-parity evaluation scoped to the
    // institute, AgDR-0003 / #28).
    match /session_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() ||
        isSupervisorOfRecordStudent(request.resource.data);
      // A supervisor must own BOTH the existing record's student AND the
      // incoming record's student (institute-scoped), so they can neither edit
      // a record outside their institute nor repoint student_id to a student in
      // another institute. Mirrors the dual-check on the students update rule.
      allow update: if isTeacher() ||
        (isSupervisorOfRecordStudent(resource.data) &&
         isSupervisorOfRecordStudent(request.resource.data));
    }

    // Sard records — TEACHER-ONLY (al_rasikhoon-801). سرد is conducted by the
    // TEACHER; the supervisor conducts الاختبار (see exam_records below). This
    // REVERSES #29, which had made Sard supervisor-only: the supervisor write
    // is removed and the teacher write restored. SardRecordModel always named
    // its author `teacher_id` — model and rule now agree again.
    //
    // Teacher writes are unscoped, identical to session_records above: any
    // teacher may write any student's sard record. That is a real gap, tracked
    // in al_rasikhoon-ob7 (which tightens session_records and sard_records
    // together); it is NOT new here. Reads stay open (authenticated).
    match /sard_records/{sardId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
    }

    // Exam records
    match /exam_records/{examId} {
      allow read: if isAuthenticated();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
    }

    // Teacher-Institute mapping
    match /teacher_institutes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Supervisor-Institute mapping
    match /supervisor_institutes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Home practice records (students can manage their own)
    match /home_practices/{practiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && getUserRole() == 'student';
      allow update, delete: if isAuthenticated() && getUserRole() == 'student';
    }
  }
}
