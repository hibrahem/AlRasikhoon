rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isSupervisor() {
      return isAuthenticated() && getUserRole() == 'supervisor';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow create if: super_admin, teacher, OR user creating their own doc (for migration)
      allow create: if isSuperAdmin() || isTeacher() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isSuperAdmin() || request.auth.uid == userId;
      // Allow delete if: super_admin OR user deleting their old migrated doc (phone must match)
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.phone == request.auth.token.phone_number);
    }

    // Institutes collection
    match /institutes/{instituteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      // Allow update if: teacher, supervisor, OR student claiming their own record
      // (setting user_id to their own UID during migration repair)
      allow update: if isTeacher() || isSupervisor() ||
        (isAuthenticated() &&
         getUserRole() == 'student' &&
         request.resource.data.user_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user_id', 'updated_at']));
      allow delete: if isSuperAdmin();
    }

    // Curriculum (read-only for all authenticated users)
    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Session records
    match /session_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
    }

    // Sard records
    match /sard_records/{sardId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
    }

    // Exam records
    match /exam_records/{examId} {
      allow read: if isAuthenticated();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
    }

    // Teacher-Institute mapping
    match /teacher_institutes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Supervisor-Institute mapping
    match /supervisor_institutes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Home practice records (students can manage their own)
    match /home_practices/{practiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && getUserRole() == 'student';
      allow update, delete: if isAuthenticated() && getUserRole() == 'student';
    }
  }
}
