rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isSupervisor() {
      return isAuthenticated() && getUserRole() == 'supervisor';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    function isStudentRole() {
      return isAuthenticated() && getUserRole() == 'student';
    }

    function isGuardian() {
      return isAuthenticated() && getUserRole() == 'guardian';
    }

    // Membership check: is the signed-in supervisor ASSIGNED to `instituteId`?
    // (al_rasikhoon-3n6) This RETIRES the single-institute model where
    // users/{uid}.institute_id was the source of truth for supervisor scoping.
    // A supervisor now has teacher parity: freely assigned/unassigned to
    // institutes and may supervise SEVERAL at once. The source of truth is the
    // membership doc supervisor_institutes/{uid}_{instituteId}.
    //
    // Because the doc id is exactly {uid}_{instituteId}, membership is a single
    // deterministic doc lookup — NO multi-hop read, NO collection query, NO
    // fan-out. We also require is_active == true: removeSupervisorFromInstitute
    // SOFT-deletes (sets is_active:false) rather than deleting the doc, so a bare
    // exists() would keep granting a REMOVED supervisor. The exists() guard runs
    // first so get() is only reached for a doc that is present (a get() on a
    // missing doc would error-and-deny anyway; this keeps it cheap and explicit).
    //
    // ⚠️ PRIVILEGE BOUNDARY: supervisor_institutes is admin-write-only (see its
    // match block below). If a supervisor could create
    // supervisor_institutes/{ownUid}_{anyInstitute} they would grant themselves
    // that institute — the escalation this whole model must prevent.
    function supervisorInInstitute(instituteId) {
      return instituteId != null &&
        exists(/databases/$(database)/documents/supervisor_institutes/$(request.auth.uid + '_' + instituteId)) &&
        get(/databases/$(database)/documents/supervisor_institutes/$(request.auth.uid + '_' + instituteId)).data.is_active == true;
    }

    // A supervisor scoped to the institute of the given student document data.
    // Compares student.institute_id against the supervisor's MEMBERSHIP docs
    // (supervisorInInstitute, al_rasikhoon-3n6) with NO multi-hop read (AgDR-0003
    // denormalizes institute_id onto student docs). Defensive against students
    // that pre-date the field: a student with no institute_id ('institute_id' in
    // data == false) is treated as out-of-scope and DENIED, so a missing field
    // never widens access. Backfilling existing student docs is a tracked
    // follow-up.
    function isSupervisorOfStudentInstitute(studentData) {
      return isSupervisor() &&
        ('institute_id' in studentData) &&
        studentData.institute_id != null &&
        supervisorInInstitute(studentData.institute_id);
    }

    // A teacher scoped to their OWN students. "A teacher's student" is
    // students.teacher_id == the caller's uid (StudentModel.teacherId, the
    // server-side counterpart of getStudentsForTeacher's client
    // .where('teacher_id', ...)). Fail-closed when the field is absent: a
    // teacher-less student ('teacher_id' in data == false) is out-of-scope and
    // DENIED, so a missing field never widens access (al_rasikhoon-ob7).
    function isTeacherOfStudent(studentData) {
      return isTeacher() &&
        ('teacher_id' in studentData) &&
        studentData.teacher_id == request.auth.uid;
    }

    // A supervisor scoped to the institute of the student referenced by a
    // session/exam record. Single get() on the student doc to read its
    // denormalized institute_id, checked against the supervisor's MEMBERSHIP
    // (supervisorInInstitute, al_rasikhoon-3n6). Fail-closed when the student has
    // no institute_id: get().data.institute_id is then null, and
    // supervisorInInstitute(null) returns false.
    function isSupervisorOfRecordStudent(recordData) {
      return isSupervisor() &&
        ('student_id' in recordData) &&
        supervisorInInstitute(get(/databases/$(database)/documents/students/$(recordData.student_id)).data.institute_id);
    }

    // A teacher scoped to the student referenced by a session/sard record.
    // Single get() on the student doc to read its denormalized teacher_id,
    // compared against the caller's uid. Scopes on the STUDENT's teacher_id —
    // NOT the record's author teacher_id — so a teacher cannot self-author a
    // record for another teacher's student (al_rasikhoon-ob7). Mirrors
    // isSupervisorOfRecordStudent; fail-closed when the student has no
    // teacher_id (null == uid is false).
    function isTeacherOfRecordStudent(recordData) {
      return isTeacher() &&
        ('student_id' in recordData) &&
        get(/databases/$(database)/documents/students/$(recordData.student_id)).data.teacher_id == request.auth.uid;
    }

    // === Read-scoping helpers (al_rasikhoon-bpk) =============================
    // Reads were previously `allow read: if isAuthenticated()` on students and
    // every record collection, so any signed-in user could read every student
    // and all progress across institutes. The helpers below scope reads by role
    // and REUSE the existing write-side institute primitives so read and write
    // stay consistent. al_rasikhoon-3n6 migrated the supervisor primitive
    // (supervisorInInstitute) from users/{uid}.institute_id to
    // supervisor_institutes membership, so BOTH read and write scoping picked up
    // multi-institute support at once.

    // A guardian may read a student they are the guardian of. The guardian↔child
    // link is students.guardian_id == the caller's uid (server-side counterpart
    // of getStudentsByGuardianId's client .where('guardian_id', ...)). Fail-closed
    // when the field is absent.
    function isGuardianOfStudent(studentData) {
      return isGuardian() &&
        ('guardian_id' in studentData) &&
        studentData.guardian_id == request.auth.uid;
    }

    // A student may read their OWN student document: students.user_id == the
    // caller's uid (server-side counterpart of getStudentByUserId's client
    // .where('user_id', ...)). Fail-closed when the field is absent.
    function isOwnStudentRecord(studentData) {
      return isStudentRole() &&
        ('user_id' in studentData) &&
        studentData.user_id == request.auth.uid;
    }

    // Who may READ a given student document.
    //  - admin      → all
    //  - teacher    → only their OWN students, scoped by students.teacher_id via
    //                 isTeacherOfStudent (al_rasikhoon-ob7). This closes the
    //                 cross-institute hole bpk left open: the only teacher read
    //                 flow is getStudentsForTeacher (already teacher_id-scoped),
    //                 so no legitimate flow needs another teacher's students.
    //  - supervisor → students of their institute, via the SAME helper the write
    //                 side uses (isSupervisorOfStudentInstitute, AgDR-0003)
    //  - guardian   → only their children
    //  - student    → only their own record
    function canReadStudent(studentData) {
      return isSuperAdmin() ||
        isTeacherOfStudent(studentData) ||
        isSupervisorOfStudentInstitute(studentData) ||
        isGuardianOfStudent(studentData) ||
        isOwnStudentRecord(studentData);
    }

    // Records (session/sard/exam) carry a denormalized student_id but NO
    // institute_id, so read-scoping a record goes through its student — the same
    // single get() the supervisor WRITE path already uses. The role gates
    // (isGuardian()/isStudentRole()) short-circuit BEFORE the get(), so it only
    // runs for the caller class that actually needs it.
    function recordStudentData(recordData) {
      return get(/databases/$(database)/documents/students/$(recordData.student_id)).data;
    }

    function isGuardianOfRecordStudent(recordData) {
      return isGuardian() &&
        ('student_id' in recordData) &&
        recordStudentData(recordData).guardian_id == request.auth.uid;
    }

    function isOwnRecord(recordData) {
      return isStudentRole() &&
        ('student_id' in recordData) &&
        recordStudentData(recordData).user_id == request.auth.uid;
    }

    // Who may READ a given session/sard/exam record. Same role matrix as
    // canReadStudent, resolved through the record's student. Teacher reads are
    // scoped to the record's student's teacher_id (isTeacherOfRecordStudent,
    // al_rasikhoon-ob7) — symmetric with the teacher WRITE scoping below.
    function canReadRecord(recordData) {
      return isSuperAdmin() ||
        isTeacherOfRecordStudent(recordData) ||
        isSupervisorOfRecordStudent(recordData) ||
        isGuardianOfRecordStudent(recordData) ||
        isOwnRecord(recordData);
    }

    // Users collection
    match /users/{userId} {
      // Reads require auth. The username+password flow looks up users
      // from authenticated callers only (admin screens checking
      // username uniqueness, the auth listener loading the signed-in
      // user's doc, etc.). The legacy unauthenticated read carve-out
      // for email-link sign-in is gone.
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isTeacher() ||
        (isAuthenticated() && request.auth.uid == userId);
      // SuperAdmin may update any field on any user. A self-update (a
      // non-superadmin editing their own doc) is allowed for normal profile
      // fields ONLY — `role` and `institute_id` are frozen to their current
      // values. Freezing `role` is the load-bearing guard: without it a
      // supervisor could self-promote to role: 'super_admin' (mirrored into the
      // Auth claim by syncRoleClaim). `institute_id` is ALSO frozen here as
      // defense-in-depth; note that as of al_rasikhoon-3n6 it is NO LONGER the
      // source of truth for supervisor scoping (that moved to the
      // supervisor_institutes membership docs, which are admin-write-only), so
      // this freeze is now belt-and-suspenders rather than the primary boundary.
      // Privilege boundary: only a superadmin may move a user between roles, and
      // only a superadmin may write supervisor_institutes memberships.
      allow update: if isSuperAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.institute_id == resource.data.institute_id);
      allow delete: if isSuperAdmin();
    }

    // Institutes collection
    match /institutes/{instituteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Students collection
    match /students/{studentId} {
      // Reads are scoped by role (al_rasikhoon-bpk): admin/teacher see all,
      // supervisor sees their institute, guardian sees their children, student
      // sees only their own doc. A blanket authenticated read here previously
      // exposed every student across institutes.
      allow read: if canReadStudent(resource.data);
      // Allow create if: a teacher creating a student assigned to THEMSELVES
      // (isTeacherOfStudent on the incoming doc requires teacher_id ==
      // request.auth.uid — the only teacher create flow, add_student_screen,
      // always sets teacher_id to the teacher's own uid), supervisor (only
      // within their own institute — teacher-parity student management,
      // AgDR-0003 / #28), OR student creating their own record (for invitation
      // flow). A bare isTeacher() here previously let any teacher create a
      // student assigned to ANOTHER teacher / institute (al_rasikhoon-9qz).
      allow create: if isTeacherOfStudent(request.resource.data) ||
        isSupervisorOfStudentInstitute(request.resource.data) ||
        (isAuthenticated() && getUserRole() == 'student' && request.resource.data.user_id == request.auth.uid);
      // Allow update if: a teacher owns the student on BOTH the existing doc and
      // the incoming doc (isTeacherOfStudent on old AND new — the caller must
      // already be the student's teacher, and the new teacher_id must remain the
      // caller). This lets a teacher edit only their OWN student (advance
      // session writing current_session*/curriculum_completed, set pace, bump
      // attempts) while blocking two attacks a bare isTeacher() left open
      // (al_rasikhoon-9qz): tampering with ANOTHER teacher's student, and
      // repointing an owned student's teacher_id to someone else. Mirrors the
      // dual old/new check on the session_records update rule. The legitimate
      // "assign a teacher to a teacher-less student" flow is SUPERVISOR-driven
      // (assign_teacher_dialog → assignTeacher) and rides the supervisor branch
      // below, which turns on institute_id only — so no teacher-branch carve-out
      // for a teacher-less old doc is needed (there is no such teacher flow), and
      // the teacher branch stays fail-closed on a missing teacher_id. Supervisor
      // is scoped to their institute on BOTH the existing and incoming doc, so a
      // supervisor can neither edit a student outside their institute nor move
      // one in/out of it. OR student claiming their own record (setting user_id
      // to their own UID during migration repair).
      allow update: if (isTeacherOfStudent(resource.data) &&
         isTeacherOfStudent(request.resource.data)) ||
        (isSupervisorOfStudentInstitute(resource.data) &&
         isSupervisorOfStudentInstitute(request.resource.data)) ||
        (isAuthenticated() &&
         getUserRole() == 'student' &&
         request.resource.data.user_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user_id', 'updated_at']));
      allow delete: if isSuperAdmin();

      // Append-only audit of pre-start starting-point moves (al_rasikhoon-sne):
      // who moved whom, and from/to which anchor. A supervisor scoped to the
      // student's institute may append an entry; the same roles that may read
      // the student may read its audit. Entries are immutable (no update/delete)
      // so the trail cannot be rewritten. This is a NARROW, feature-local rule —
      // it does not touch the institute-scoping primitives (al_rasikhoon-3n6).
      match /reposition_audit/{auditId} {
        function parentStudent() {
          return get(/databases/$(database)/documents/students/$(studentId)).data;
        }
        allow read: if canReadStudent(parentStudent());
        allow create: if isSupervisorOfStudentInstitute(parentStudent());
        allow update, delete: if false;
      }
    }

    // Curriculum (read-only for all authenticated users)
    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Session records — a teacher writes only for their OWN students; a
    // supervisor writes only for a student in their own institute (teacher-parity
    // evaluation scoped to the institute, AgDR-0003 / #28). Teacher scoping goes
    // through the record's student's teacher_id (al_rasikhoon-ob7), so a teacher
    // can no longer fabricate/alter another teacher's student's progress.
    match /session_records/{recordId} {
      // Read-scoped by role through the record's student (al_rasikhoon-bpk +
      // al_rasikhoon-ob7 for the teacher scope).
      allow read: if canReadRecord(resource.data);
      allow create: if isTeacherOfRecordStudent(request.resource.data) ||
        isSupervisorOfRecordStudent(request.resource.data);
      // A teacher (like a supervisor) must own BOTH the existing record's
      // student AND the incoming record's student, so they can neither edit a
      // record for a student that is not theirs nor repoint student_id onto
      // another teacher's student. Mirrors the dual old/new check on the
      // students update rule.
      allow update: if (isTeacherOfRecordStudent(resource.data) &&
         isTeacherOfRecordStudent(request.resource.data)) ||
        (isSupervisorOfRecordStudent(resource.data) &&
         isSupervisorOfRecordStudent(request.resource.data));
    }

    // Sard records — TEACHER-ONLY (al_rasikhoon-801). سرد is conducted by the
    // TEACHER; the supervisor conducts الاختبار (see exam_records below). This
    // REVERSES #29, which had made Sard supervisor-only: the supervisor write
    // is removed and the teacher write restored. SardRecordModel always named
    // its author `teacher_id` — model and rule now agree again.
    //
    // Teacher writes are scoped to the teacher's OWN students, identical to
    // session_records above (al_rasikhoon-ob7): a teacher may create/update a
    // sard record only when the record's student's teacher_id is the caller, and
    // on update must own BOTH the old and new student so student_id cannot be
    // repointed onto another teacher's student.
    match /sard_records/{sardId} {
      // Read-scoped by role through the record's student (al_rasikhoon-bpk +
      // al_rasikhoon-ob7 for the teacher scope).
      allow read: if canReadRecord(resource.data);
      allow create: if isTeacherOfRecordStudent(request.resource.data);
      allow update: if isTeacherOfRecordStudent(resource.data) &&
        isTeacherOfRecordStudent(request.resource.data);
    }

    // Exam records
    match /exam_records/{examId} {
      // Read-scoped by role through the record's student (al_rasikhoon-bpk).
      allow read: if canReadRecord(resource.data);
      allow create: if isSupervisor();
      allow update: if isSupervisor();
    }

    // Teacher-Institute mapping
    match /teacher_institutes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Supervisor-Institute membership (al_rasikhoon-3n6: THE source of truth for
    // supervisor institute scoping, replacing users/{uid}.institute_id). Doc id
    // is {supervisorId}_{instituteId}; supervisorInInstitute() above reads these.
    //
    // ⚠️ ADMIN-WRITE-ONLY — THE core privilege boundary of this model. A
    // supervisor granting themselves an institute is exactly the escalation that
    // freezing users/{uid}.role/institute_id used to block; that guard MOVES HERE
    // when scoping moves here. If a supervisor could create
    // supervisor_institutes/{ownUid}_{anyInstitute}, or flip is_active on their
    // own removed membership back to true, they would self-grant that institute.
    // So EVERY write (create/update/delete) requires super_admin. The
    // createUserAccount Cloud Function and the admin assign/remove flows write via
    // the Admin SDK, which bypasses these rules; no client-role write path exists.
    // Reads stay open to any authenticated user (the client resolves a
    // supervisor's institutes and the admin lists memberships).
    match /supervisor_institutes/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // Home practice records — a student self-reports practice against their own
    // student doc. Each doc carries a denormalized student_id (see
    // HomePracticeModel), so it scopes exactly like session/sard/exam records.
    match /home_practices/{practiceId} {
      // Read-scoped by role through the practice's student (al_rasikhoon-c6e).
      // Previously `allow read: if isAuthenticated()`, so any signed-in user
      // could read every student's home practice across institutes — the same
      // leak al_rasikhoon-bpk closed for students/records. canReadRecord resolves
      // through students/{student_id}: admin, the student's teacher/supervisor/
      // guardian, and the student themself may read; it fails closed when
      // student_id is absent.
      allow read: if canReadRecord(resource.data);
      // Writes are the student's OWN practice only. isOwnRecord requires the
      // caller to be the student behind the practice's student doc
      // (students/{student_id}.user_id == request.auth.uid); previously ANY
      // student could create/update/delete ANY home_practice. On update BOTH the
      // existing and incoming student must be the caller's, so student_id cannot
      // be repointed onto another student.
      allow create: if isOwnRecord(request.resource.data);
      allow update: if isOwnRecord(resource.data) && isOwnRecord(request.resource.data);
      allow delete: if isOwnRecord(resource.data);
    }
  }
}
