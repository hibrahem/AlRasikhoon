<?xml version="1.0" encoding="UTF-8"?>
<!--
  Export options for `flutter build ipa --export-options-plist=ios/ExportOptions.plist`.

  Method "release-testing" (Xcode 15+) replaces the older "ad-hoc". It produces
  an IPA signed for the devices registered in the ad-hoc provisioning profile,
  which is what Firebase App Distribution wants for beta builds.

  Switch `method` to `app-store-connect` if you'd rather distribute through
  TestFlight instead of Firebase App Distribution.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>release-testing</string>
    <key>teamID</key>
    <string>327MX655VL</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>stripSwiftSymbols</key>
    <true/>
    <key>uploadSymbols</key>
    <true/>
</dict>
</plist>
