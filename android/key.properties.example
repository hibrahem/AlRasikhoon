# Android release signing config.
#
# 1. Generate an upload keystore (one-time, keep the .jks file outside the
#    repo or alongside it — `*.jks` is gitignored):
#
#      keytool -genkey -v -keystore ~/.keys/al_rasikhoon-upload.jks \
#        -alias al_rasikhoon -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Copy this file to android/key.properties (also gitignored) and fill in.
# 3. Build a signed bundle:
#
#      flutter build appbundle --release
#      flutter build apk --release
#
# 4. Distribute via Firebase App Distribution — see scripts/distribute_android.sh.

storeFile=/absolute/path/to/al_rasikhoon-upload.jks
storePassword=replace-me
keyAlias=al_rasikhoon
keyPassword=replace-me
